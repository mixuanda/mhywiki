{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Banner",
  "type": "object",
  "required": ["id", "game", "entityType", "version"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "game": { "enum": ["gi", "sr"] },
    "entityType": { "const": "banner" },
    "version": { "type": "string", "minLength": 1 },
    "phase": { "type": ["string", "number", "null"] },
    "featuredFiveStar": { "type": "array" },
    "featuredFourStar": { "type": "array" }
  },
  "additionalProperties": true
}
