    "Buff": {
      "_id": 3110012,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方单位被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体解除控制状态、激活终结技并回复生命值。<br>敌方全体受到的忆灵技伤害提高<color style='color:#f29e38;'> 10% </color>，战技伤害提高<color style='color:#f29e38;'> 30% </color>。"
    },
    "UB": [
      {
        "_id": 3111068,
        "Name": "披坚执锐",
        "Desc": "我方全体造成的物理属性伤害提高<color style='color:#f29e38;'> 50% </color>，敌方全体的物理属性抗性降低<color style='color:#f29e38;'> 20% </color>。"
      },
      {
        "_id": 3111069,
        "Name": "蔓草难除",
        "Desc": "我方全体施放普攻或战技攻击处于弱点击破状态下的敌人后，使其当前承受的所有持续伤害立即产生相当于原伤害<color style='color:#f29e38;'> 20% </color>的伤害。"
      },
      {
        "_id": 3111070,
        "Name": "臻冰彻骨",
        "Desc": "敌方全体受到的击破伤害提高<color style='color:#f29e38;'> 10% </color>。击破敌方弱点后，我方全体速度提高<color style='color:#f29e38;'> 20% </color>，持续<color style='color:#f29e38;'> 2 </color>回合。"
      }
    ],
    "LB": [
      {
        "_id": 3111065,
        "Name": "攻无不克",
        "Desc": "忆灵造成伤害时无视目标<color style='color:#f29e38;'> 20% </color>的防御力。"
      },
      {
        "_id": 3111066,
        "Name": "生机焕发",
        "Desc": "我方全体造成的战技伤害提高<color style='color:#f29e38;'> 30% </color>，回合开始时，若当前生命值百分比等于或低于<color style='color:#f29e38;'> 1% </color>，则回复生命上限<color style='color:#f29e38;'> 15% </color>的生命值。"
      },
      {
        "_id": 3111067,
        "Name": "破竹之势",
        "Desc": "角色施放终结技时，使自身的弱点击破效率提高<color style='color:#f29e38;'> 100% </color>，暴击伤害提高<color style='color:#f29e38;'> 40% </color>，持续<color style='color:#f29e38;'> 3 </color>回合。"
