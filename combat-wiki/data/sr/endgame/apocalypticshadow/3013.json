    "Buff": {
      "_id": 3110013,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方目标被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体目标解除控制状态、立即行动并回复生命值。<br>敌方全体目标受到的忆灵技伤害提高<color style='color:#f29e38;'> 15% </color>，终结技伤害提高<color style='color:#f29e38;'> 25% </color>。"
    },
    "UB": [
      {
        "_id": 3111071,
        "Name": "镌骨铭心",
        "Desc": "战斗开始时，我方队伍中存在2/3/4名记忆命途的角色时，敌方目标受到的伤害提高<color style='color:#f29e38;'> 5% </color>/<color style='color:#f29e38;'> 10% </color>/<color style='color:#f29e38;'> 20% </color>，该效果对所有新上场的敌人也生效。"
      },
      {
        "_id": 3111072,
        "Name": "傲雪凌霜",
        "Desc": "我方全体目标造成的冰属性伤害提高<color style='color:#f29e38;'> 50% </color>，速度提高<color style='color:#f29e38;'> 10% </color>。"
      },
      {
        "_id": 3111073,
        "Name": "登锋陷阵",
        "Desc": "队伍中的第1位角色施放终结技后，使自身的弱点击破效率提高<color style='color:#f29e38;'> 50% </color>，暴击伤害提高<color style='color:#f29e38;'> 50% </color>，持续<color style='color:#f29e38;'> 1 </color>回合。"
      }
