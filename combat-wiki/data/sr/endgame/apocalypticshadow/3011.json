    "Buff": {
      "_id": 3110011,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方单位被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体解除控制状态、恢复战技点并激活终结技。<br>敌方全体受到的持续伤害提高<color style='color:#f29e38;'> 25% </color>，战技伤害提高<color style='color:#f29e38;'> 15% </color>。"
    },
    "UB": [
      {
        "_id": 3111062,
        "Name": "戮力同心",
        "Desc": "我方目标每消耗1个战技点时，使我方全体造成的伤害提高<color style='color:#f29e38;'> 6% </color>，该效果最多叠加<color style='color:#f29e38;'> 10 </color>层。"
      },
      {
        "_id": 3111063,
        "Name": "牵丝攀藤",
        "Desc": "消灭敌方目标后，敌方全体受到的击破伤害提高<color style='color:#f29e38;'> 15% </color>，最多叠加<color style='color:#f29e38;'> 4 </color>层，该效果对所有新上场的敌人也生效。"
      },
      {
        "_id": 3111061,
        "Name": "破釜沉舟",
        "Desc": "我方目标消耗自身生命值后，暴击伤害提高<color style='color:#f29e38;'> 55% </color>，持续<color style='color:#f29e38;'> 2 </color>回合。"
      }
    ],
    "LB": [
      {
        "_id": 3111059,
        "Name": "抵瑕陷隙",
        "Desc": "我方全体造成的终结技伤害提高<color style='color:#f29e38;'> 30% </color>，对处于弱点击破状态下的敌方目标额外提高<color style='color:#f29e38;'> 30% </color>。"
      },
      {
        "_id": 3111060,
        "Name": "蔓草难除",
        "Desc": "我方全体施放普攻或战技攻击处于弱点击破状态下的敌人后，使其当前承受的所有持续伤害立即产生相当于原伤害<color style='color:#f29e38;'> 15% </color>的伤害。"
      },
      {
        "_id": 3111064,
        "Name": "登锋陷阵",
        "Desc": "队伍中的第1位角色施放终结技后，使自身的弱点击破效率提高<color style='color:#f29e38;'> 50% </color>，暴击伤害提高<color style='color:#f29e38;'> 50% </color>，持续<color style='color:#f29e38;'> 1 </color>回合。"
