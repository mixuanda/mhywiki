    "Buff": {
      "_id": 3110005,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方单位被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体行动提前并恢复战技点。<br>敌方全体受到的弱点击破伤害提高<color style='color:#f29e38;'> 20% </color>，追加攻击伤害提高<color style='color:#f29e38;'> 20% </color>。"
    },
    "UB": [
      {
        "_id": 3111030,
        "Name": "臻冰彻骨",
        "Desc": "敌方全体受到的击破伤害提高<color style='color:#f29e38;'> 10% </color>。击破敌方弱点后，我方全体速度提高<color style='color:#f29e38;'> 20% </color>，持续<color style='color:#f29e38;'> 2 </color>回合。"
      },
      {
        "_id": 3111033,
        "Name": "持续腐化",
        "Desc": "在拥有【坚防守备】的敌方单位被弱点击破前，累积受到的持续伤害值。在弱点击破后对该单位造成等同于累积伤害值<color style='color:#f29e38;'> 200% </color>的附加伤害。"
      },
      {
        "_id": 3111034,
        "Name": "风暴翻涌",
        "Desc": "我方全体造成的量子属性伤害提高<color style='color:#f29e38;'> 60% </color>。消灭敌方目标后，攻击者行动提前<color style='color:#f29e38;'> 15% </color>。"
      }
    ],
    "LB": [
      {
        "_id": 3111029,
        "Name": "作弊小抄",
        "Desc": "对我方单体目标施放战技或终结技时，使技能目标的攻击力提高<color style='color:#f29e38;'> 25% </color>，持续<color style='color:#f29e38;'> 2 </color>回合，该效果最多叠加<color style='color:#f29e38;'> 2 </color>次。"
      },
      {
        "_id": 3111032,
        "Name": "课间休息",
