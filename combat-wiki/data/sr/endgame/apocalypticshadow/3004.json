    "Buff": {
      "_id": 3110004,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方单位被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体角色恢复战技点并激活终结技。<br>敌方全体受到的弱点击破伤害提高<color style='color:#f29e38;'> 20% </color>，追加攻击伤害提高<color style='color:#f29e38;'> 20% </color>。"
    },
    "UB": [
      {
        "_id": 3111028,
        "Name": "支配万物",
        "Desc": "我方全体普攻造成的伤害提高<color style='color:#f29e38;'> 50% </color>。"
      },
      {
        "_id": 3111027,
        "Name": "意气激昂",
        "Desc": "消灭敌方目标后，我方全体目标行动提前<color style='color:#f29e38;'> 10% </color>。"
      },
      {
        "_id": 3111021,
        "Name": "时来运转",
        "Desc": "角色造成的追加攻击伤害无视敌方目标<color style='color:#f29e38;'> 15% </color>的全属性抗性，同时对非弱点目标也能削减韧性，效果等同于原技能削韧值的<color style='color:#f29e38;'> 50% </color>。"
      }
    ],
    "LB": [
      {
        "_id": 3111024,
        "Name": "乘胜追击",
        "Desc": "角色施放追加攻击后，行动提前<color style='color:#f29e38;'> 15% </color>，该效果每个角色下次行动前最多触发<color style='color:#f29e38;'> 1 </color>次。"
      },
