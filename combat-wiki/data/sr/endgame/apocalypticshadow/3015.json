    "Buff": {
      "_id": 3110014,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方目标被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体目标解除控制状态、立即行动并恢复战技点。<br>敌方全体目标受到的击破伤害提高<color style='color:#f29e38;'> 25% </color>，忆灵技伤害提高<color style='color:#f29e38;'> 15% </color>。"
    },
