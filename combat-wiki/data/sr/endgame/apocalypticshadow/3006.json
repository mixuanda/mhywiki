    "Buff": {
      "_id": 3110006,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方单位被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体解除控制状态、恢复战技点并激活终结技。<br>敌方全体受到的战技伤害提高<color style='color:#f29e38;'> 25% </color>，终结技伤害提高<color style='color:#f29e38;'> 15% </color>。"
    },
    "UB": [
      {
        "_id": 3111035,
        "Name": "以智取胜",
        "Desc": "我方队伍中存在2个或以上智识命途的角色时，我方全体的攻击力提高<color style='color:#f29e38;'> 60% </color>。"
      },
      {
        "_id": 3111036,
        "Name": "拔山举鼎",
        "Desc": "我方全体造成的物理属性伤害提高<color style='color:#f29e38;'> 50% </color>，效果抵抗提高<color style='color:#f29e38;'> 50% </color>。"
      },
      {
        "_id": 3111037,
        "Name": "猎逐步伐",
        "Desc": "我方单位击破敌方目标弱点时，行动提前<color style='color:#f29e38;'> 20% </color>。"
      }
    ],
    "LB": [
      {
        "_id": 3111038,
        "Name": "寸草不生",
        "Desc": "角色攻击处于弱点击破状态下的敌人后，其当前承受的所有持续伤害立即产生相当于原伤害<color style='color:#f29e38;'> 60% </color>的伤害，该效果单个回合内每个角色各自最多触发<color style='color:#f29e38;'> 1 </color>次。"
      },
      {
        "_id": 3111039,
        "Name": "牵丝攀藤",
        "Desc": "消灭敌方目标后，敌方全体受到的击破伤害提高<color style='color:#f29e38;'> 5% </color>，最多叠加<color style='color:#f29e38;'> 5 </color>层，该效果对所有新上场的敌人也生效。"
      },
      {
        "_id": 3111040,
        "Name": "势如破竹",
