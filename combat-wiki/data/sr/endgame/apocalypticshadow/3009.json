    "Buff": {
      "_id": 3110009,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方单位被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体解除控制状态、恢复战技点并激活终结技。<br>我方全体受到的回复量提高<color style='color:#f29e38;'> 50% </color>。"
    },
    "UB": [
      {
        "_id": 3111053,
        "Name": "破晓之召",
        "Desc": "忆灵的弱点击破效率提高<color style='color:#f29e38;'> 50% </color>，忆灵造成伤害时无视目标<color style='color:#f29e38;'> 20% </color>的防御力。"
      },
      {
        "_id": 3111018,
        "Name": "寸草不生",
        "Desc": "角色攻击处于弱点击破状态下的敌人后，其当前承受的所有持续伤害立即产生相当于原伤害<color style='color:#f29e38;'> 80% </color>的伤害，该效果单个回合内每个角色各自最多触发<color style='color:#f29e38;'> 2 </color>次。"
      },
      {
        "_id": 3111020,
        "Name": "势如破竹",
        "Desc": "造成的终结技伤害的暴击伤害提高<color style='color:#f29e38;'> 30% </color>，对处于弱点击破状态下的敌方目标额外提高<color style='color:#f29e38;'> 30% </color>。"
      }
    ],
    "LB": [
      {
        "_id": 3111055,
        "Name": "血战狂澜",
        "Desc": "我方全体造成的物理属性伤害提高<color style='color:#f29e38;'> 50% </color>，施放战技时恢复自身<color style='color:#f29e38;'> 20% </color>的生命值。"
      },
      {
        "_id": 3111021,
        "Name": "时来运转",
        "Desc": "角色造成的追加攻击伤害无视敌方目标<color style='color:#f29e38;'> 15% </color>的全属性抗性，同时对非弱点目标也能削减韧性，效果等同于原技能削韧值的<color style='color:#f29e38;'> 50% </color>。"
      },
      {
        "_id": 3111030,
        "Name": "臻冰彻骨",
        "Desc": "敌方全体受到的击破伤害提高<color style='color:#f29e38;'> 10% </color>。击破敌方弱点后，我方全体速度提高<color style='color:#f29e38;'> 20% </color>，持续<color style='color:#f29e38;'> 2 </color>回合。"
      }
