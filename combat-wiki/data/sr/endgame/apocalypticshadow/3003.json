    "Buff": {
      "_id": 3110003,
      "Name": "末法余烬",
      "Desc": "拥有<color style='color:#f29e38;'>【坚防守备】</color>的敌方单位被<color style='color:#f29e38;'>弱点击破</color>时，使我方全体行动提前并恢复战技点。<br>敌方全体受到的追加攻击伤害提高<color style='color:#f29e38;'> 25% </color>，终结技伤害提高<color style='color:#f29e38;'> 15% </color>。"
    },
    "UB": [
      {
        "_id": 3111021,
        "Name": "时来运转",
        "Desc": "角色造成的追加攻击伤害无视敌方目标<color style='color:#f29e38;'> 15% </color>的全属性抗性，同时对非弱点目标也能削减韧性，效果等同于原技能削韧值的<color style='color:#f29e38;'> 50% </color>。"
      },
      {
        "_id": 3111022,
        "Name": "千金一掷",
        "Desc": "角色造成的冰属性伤害提高<color style='color:#f29e38;'> 55% </color>。"
      },
      {
        "_id": 3111023,
        "Name": "追亡逐北",
        "Desc": "角色击破敌方目标弱点时，行动提前<color style='color:#f29e38;'> 15% </color>，该效果每回合最多触发<color style='color:#f29e38;'> 1 </color>次。"
      }
    ],
    "LB": [
      {
        "_id": 3111018,
        "Name": "寸草不生",
        "Desc": "角色攻击处于弱点击破状态下的敌人后，其当前承受的所有持续伤害立即产生相当于原伤害<color style='color:#f29e38;'> 80% </color>的伤害，该效果单个回合内每个角色各自最多触发<color style='color:#f29e38;'> 2 </color>次。"
      },
      {
        "_id": 3111019,
        "Name": "牵丝攀藤",
        "Desc": "消灭敌方目标后，敌方全体受到的击破伤害提高<color style='color:#f29e38;'> 5% </color>，最多叠加<color style='color:#f29e38;'> 5 </color>层，该效果对所有新上场的敌人也生效。"
      },
