  "content": {
    "_id": 2019,
    "Name": "程式句法",
    "Blessing": [
      {
        "_id": 3031217,
        "Name": "触发持续伤害",
        "Desc": "敌方目标每次受到持续伤害后，使我方额外积累<color style='color:#f29e38;'> 2 </color>点「战意值」。"
      },
      {
        "_id": 3031218,
        "Name": "战熄潮平",
        "Desc": "敌方目标进入战斗时陷入<color style='color:#f29e38;'> 1 </color>层特殊<color style='color:#f29e38;'>风化</color>【迷音】，行动后陷入<color style='color:#f29e38;'> 1 </color>层【迷音】，每回合开始时受到风属性持续伤害，最多叠加<color style='color:#f29e38;'> 10 </color>层，持续<color style='color:#f29e38;'> 3 </color>回合。"
      },
      {
        "_id": 3031219,
        "Name": "战意汹涌",
        "Desc": "进入「战意汹涌」时使敌方全体陷入<color style='color:#f29e38;'> 5 </color>层特殊<color style='color:#f29e38;'>风化</color>【迷音】，并使其当前承受的所有持续伤害立即产生相当于原伤害<color style='color:#f29e38;'> 100% </color>的伤害。「战意汹涌」期间敌方目标受到的伤害提高<color style='color:#f29e38;'> 50% </color>，造成的伤害降低<color style='color:#f29e38;'> 35% </color>，速度提高<color style='color:#f29e38;'> 50% </color>。"
      }
    ],
    "Buffs": [
      {
        "_id": 3031340,
        "Name": "直叙",
        "Desc": "「战意汹涌」期间，我方目标造成的持续伤害无视目标<color style='color:#f29e38;'> 20% </color>的全属性抗性，敌方目标受到持续伤害后，使我方全体造成的持续伤害提高<color style='color:#f29e38;'> 1% </color>，最多叠加<color style='color:#f29e38;'> 99 </color>层，持续至「战意汹涌」结束。",
        "SimpleDesc": ""
      },
      {
        "_id": 3031350,
        "Name": "裂帛",
        "Desc": "「战意汹涌」期间，每层【迷音】使我方目标造成伤害时的弱点击破效率提高<color style='color:#f29e38;'> 10% </color>。",
        "SimpleDesc": "敌方目标的弱点被击破时，使我方额外积累<color style='color:#f29e38;'> 5 </color>点「战意值」。"
      },
      {
        "_id": 3031351,
        "Name": "书丹",
        "Desc": "每层【迷音】使敌方目标受到的伤害提高<color style='color:#f29e38;'> 3% </color>。「战意汹涌」期间，忆灵攻击后使目标陷入<color style='color:#f29e38;'> 1 </color>层【迷音】。",
        "SimpleDesc": "忆灵攻击后每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      }
    ],
