    "Blessing": {
      "_id": 3031001,
      "Name": "词语爆裂",
      "Desc": "我方施放终结技攻击敌方目标时，为目标附上【爆裂】，最多叠加<color style='color:#f29e38;'> 6 </color>层。目标的回合开始或目标被消灭时，根据【爆裂】层数对该目标及其相邻目标造成固定数值的伤害。"
    },
    "Buffs": [
      {
        "_id": 3031310,
        "Name": "诱发",
        "Desc": "我方施放战技攻击敌方目标时，有<color style='color:#f29e38;'> 80% </color>固定概率为目标附上【爆裂】。"
      },
      {
        "_id": 3031311,
        "Name": "殉爆",
        "Desc": "敌方目标施放技能时使自身及相邻目标陷入1层【灼伤】。处于【灼伤】状态中的敌方目标受到的伤害提高<color style='color:#f29e38;'> 10% </color>，该效果最多叠加<color style='color:#f29e38;'> 3 </color>层，且对触发怪诞逸闻效果造成的固定伤害也生效。"
      },
      {
        "_id": 3031312,
        "Name": "喷溅",
        "Desc": "角色施放终结技进行攻击后，行动提前<color style='color:#f29e38;'> 25% </color>，且造成的伤害提高<color style='color:#f29e38;'> 100% </color>，持续<color style='color:#f29e38;'> 1 </color>回合。"
      }
    ],
