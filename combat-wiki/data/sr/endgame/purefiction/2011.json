  "content": {
    "_id": 2011,
    "Name": "深文巧诋",
    "Blessing": [
      {
        "_id": 3031202,
        "Name": "战技攻击",
        "Desc": "我方施放战技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 5 </color>点「战意值」。"
      },
      {
        "_id": 3031203,
        "Name": "战熄潮平",
        "Desc": "战斗开始时，我方施放战技攻击敌方目标后，对每个被攻击的敌方目标造成固定数值的伤害。"
      },
      {
        "_id": 3031204,
        "Name": "战意汹涌",
        "Desc": "进入「战意汹涌」时，我方全体行动提前<color style='color:#f29e38;'> 100% </color>，期间敌方目标受到的伤害提高<color style='color:#f29e38;'> 50% </color>，且我方施放战技攻击敌方目标后，额外对每个被攻击的敌方目标的相邻目标造成固定数值的伤害。"
      }
    ],
    "Buffs": [
      {
        "_id": 3031327,
        "Name": "肤廓",
        "Desc": "「战意汹涌」期间，我方全体战技不消耗战技点。角色施放战技或终结技后，每击中1个敌方目标获得1层【热潮】，每层使该角色造成的战技和终结技伤害提高<color style='color:#f29e38;'> 4% </color>，速度提高<color style='color:#f29e38;'> 4% </color>，最多叠加<color style='color:#f29e38;'> 10 </color>层。",
        "SimpleDesc": "我方施放终结技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      },
      {
        "_id": 3031328,
        "Name": "乌有",
        "Desc": "「战意汹涌」期间，我方全体造成的追加攻击伤害提高<color style='color:#f29e38;'> 40% </color>，发动追加攻击后，对每个被攻击的敌方目标及其相邻目标造成固定数值的伤害。",
        "SimpleDesc": "我方发动追加攻击后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 2 </color>点「战意值」。"
      },
      {
        "_id": 3031329,
        "Name": "空头",
        "Desc": "「战意汹涌」期间，敌方目标受到的击破伤害提高<color style='color:#f29e38;'> 30% </color>，我方角色击破敌方目标弱点时，自身行动提前<color style='color:#f29e38;'> 12% </color>。",
        "SimpleDesc": "我方攻击敌方目标后，每击破1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      }
    ],
