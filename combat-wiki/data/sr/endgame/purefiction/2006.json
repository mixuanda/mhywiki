    "Blessing": {
      "_id": 3031002,
      "Name": "恶语钝刀",
      "Desc": "敌方目标受到的持续伤害提高<color style='color:#f29e38;'> 35% </color>。受到持续伤害的敌方目标造成的伤害降低<color style='color:#f29e38;'> 35% </color>，被攻击后行动提前<color style='color:#f29e38;'> 35% </color>。"
    },
    "Buffs": [
      {
        "_id": 3031316,
        "Name": "批驳",
        "Desc": "敌方目标被消灭时，持有的持续伤害有<color style='color:#f29e38;'> 100% </color>基础概率转移给全体敌人。"
      },
      {
        "_id": 3031317,
        "Name": "立论",
        "Desc": "敌方目标进入战斗时，陷入风化状态，每回合开始时受到固定数值的风属性持续伤害，并使自身与相邻敌方目标陷入风化状态。"
      },
      {
        "_id": 3031318,
        "Name": "辨伪",
        "Desc": "我方队伍中存在3名或以上的[虚无] 命途角色时，我方全体造成的伤害提高<color style='color:#f29e38;'> 60% </color>，速度提高<color style='color:#f29e38;'> 30% </color>。"
      }
