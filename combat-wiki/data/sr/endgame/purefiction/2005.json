    "_id": 2005,
    "Name": "作言造语",
    "Blessing": {
      "_id": 3031003,
      "Name": "巧言令色",
      "Desc": "我方施放的追加攻击造成伤害后，累计造成的伤害值。当伤害值累计达到 100% 时，对敌方全体造成固定数值的伤害。"
    },
    "Buffs": [
      {
        "_id": 3031313,
        "Name": "追问",
        "Desc": "【怪诞逸闻】效果不再需要累计追加攻击造成的伤害值，改为我方每施放<color style='color:#f29e38;'> 3 </color>次追加攻击后触发，并使该效果造成的伤害提高<color style='color:#f29e38;'> 60% </color>。"
      },
      {
        "_id": 3031314,
        "Name": "引申",
        "Desc": "触发【怪诞逸闻】效果时，同时为我方全体恢复等同于能量上限<color style='color:#f29e38;'> 35% </color>的能量。该效果恢复的能量可以超出目标的能量上限。"
      },
      {
        "_id": 3031315,
        "Name": "归谬",
        "Desc": "我方造成的除追加攻击以外的其他所有类型的伤害也都可以累计等同于原数值<color style='color:#f29e38;'> 18% </color>的进度。"
      }
    ],
