    "_id": 2010,
    "Name": "论黄数黑",
    "Blessing": {
      "_id": 3031002,
      "Name": "恶语钝刀",
      "Desc": "敌方目标受到的持续伤害提高<color style='color:#f29e38;'> 35% </color>。受到持续伤害的敌方目标造成的伤害降低<color style='color:#f29e38;'> 35% </color>，被攻击后行动提前<color style='color:#f29e38;'> 35% </color>。"
    },
    "Buffs": [
      {
        "_id": 3031330,
        "Name": "噱头",
        "Desc": "我方全体击破特攻提高<color style='color:#f29e38;'> 30% </color>，击破敌方目标时会令敌方全体陷入风化状态，每回合开始时受到固定数值的风属性持续伤害。<br>敌方全体免疫控制类负面状态。"
      },
      {
        "_id": 3031331,
        "Name": "醉话",
        "Desc": "我方目标施放终结技攻击敌方目标后，若目标当前承受1/2/3种持续伤害状态，则会使其当前承受的每种持续伤害状态立即产生相当于原伤害<color style='color:#f29e38;'> 60% </color>/<color style='color:#f29e38;'> 100% </color>/<color style='color:#f29e38;'> 150% </color>的伤害。"
      },
      {
        "_id": 3031305,
        "Name": "谣诼",
        "Desc": "我方攻击敌方目标后，会使目标陷入风化状态，每回合开始时受到固定数值的风属性持续伤害。"
      }
    ],
