  "content": {
    "_id": 2013,
    "Name": "自证预言",
    "Blessing": [
      {
        "_id": 3031212,
        "Name": "终结技/普攻攻击",
        "Desc": "我方施放普攻或终结技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      },
      {
        "_id": 3031213,
        "Name": "战熄潮平",
        "Desc": "我方施放普攻或终结技攻击敌方目标时，为目标附上【爆裂】，最多叠加<color style='color:#f29e38;'> 3 </color>层。目标的回合开始或被任意单位消灭时，根据【爆裂】层数对该目标造成真实伤害。"
      },
      {
        "_id": 3031214,
        "Name": "战意汹涌",
        "Desc": "进入「战意汹涌」时，立即为我方全体恢复<color style='color:#f29e38;'> 30% </color>能量，该效果恢复的能量可以超出目标的能量上限。期间敌方目标受到的伤害提高<color style='color:#f29e38;'> 50% </color>，且触发【爆裂】时会对该目标及其相邻目标造成真实伤害。"
      }
    ],
    "Buffs": [
      {
        "_id": 3031335,
        "Name": "显化",
        "Desc": "「战意汹涌」期间，我方对处于【爆裂】的敌方目标施放战技或发动追加攻击后可以直接触发【爆裂】。",
        "SimpleDesc": "我方施放战技或发动追加攻击后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 2 </color>点「战意值」。"
      },
      {
        "_id": 3031336,
        "Name": "灵知",
        "Desc": "「战意汹涌」期间，敌方目标受到的击破伤害提高<color style='color:#f29e38;'> 30% </color>，且处于【爆裂】状态的目标被任意单位消灭时会对相邻敌方目标造成<color style='color:#f29e38;'> 10 </color>点无视弱点属性的削韧。",
        "SimpleDesc": "敌方目标的弱点被击破时，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      },
      {
        "_id": 3031337,
        "Name": "神智",
        "Desc": "「战意汹涌」期间，我方全体施放战技时消耗等同于自身当前生命值<color style='color:#f29e38;'> 20% </color>的生命值，并在施放战技后回复等同于自身生命上限<color style='color:#f29e38;'> 20% </color>的生命值。",
        "SimpleDesc": "我方全体角色每次受到攻击或损失生命值时，使我方额外积累<color style='color:#f29e38;'> 2 </color>点「战意值」。"
      }
    ],
