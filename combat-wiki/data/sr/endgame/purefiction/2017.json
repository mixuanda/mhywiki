  "content": {
    "_id": 2017,
    "Name": "主观叙事",
    "Blessing": [
      {
        "_id": 3031202,
        "Name": "战技攻击",
        "Desc": "我方施放战技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 5 </color>点「战意值」。"
      },
      {
        "_id": 3031203,
        "Name": "战熄潮平",
        "Desc": "战斗开始时，我方施放战技攻击敌方目标后，对每个被攻击的敌方目标造成固定数值的伤害。"
      },
      {
        "_id": 3031204,
        "Name": "战意汹涌",
        "Desc": "进入「战意汹涌」时，我方全体行动提前<color style='color:#f29e38;'> 100% </color>，期间敌方目标受到的伤害提高<color style='color:#f29e38;'> 50% </color>，且我方施放战技攻击敌方目标后，额外对每个被攻击的敌方目标的相邻目标造成固定数值的伤害。"
      }
    ],
    "Buffs": [
      {
        "_id": 3031344,
        "Name": "谣曲",
        "Desc": "「战意汹涌」期间，忆灵造成的伤害提高<color style='color:#f29e38;'> 30% </color>，当忆灵消失时，使忆师行动提前<color style='color:#f29e38;'> 15% </color>。",
        "SimpleDesc": "忆灵攻击后每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      },
      {
        "_id": 3031345,
        "Name": "奏雅",
        "Desc": "进入「战意汹涌」时，立即恢复<color style='color:#f29e38;'> 3 </color>个战技点。「战意汹涌」期间，敌方目标受到的持续伤害提高<color style='color:#f29e38;'> 30% </color>。",
        "SimpleDesc": "敌方目标每次受到持续伤害后，使我方额外积累<color style='color:#f29e38;'> 1 </color>点「战意值」。"
      },
      {
        "_id": 3031346,
        "Name": "孤韵",
        "Desc": "「战意汹涌」期间，我方施放战技攻击敌方目标后，对每个被攻击的敌方目标额外造成等同于原伤害<color style='color:#f29e38;'> 30% </color>的真实伤害。",
        "SimpleDesc": ""
      }
    ],
