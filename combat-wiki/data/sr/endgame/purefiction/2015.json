  "content": {
    "_id": 2015,
    "Name": "叙事分析",
    "Blessing": [
      {
        "_id": 3031207,
        "Name": "终结技攻击",
        "Desc": "我方施放终结技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 5 </color>点「战意值」。"
      },
      {
        "_id": 3031208,
        "Name": "战熄潮平",
        "Desc": "敌方目标被任意单位消灭后，为我方全体附上1层【回音】。"
      },
      {
        "_id": 3031209,
        "Name": "战意汹涌",
        "Desc": "进入「战意汹涌」时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。「战意汹涌」期间，敌方目标受到的伤害提高<color style='color:#f29e38;'> 50% </color>，且被任意单位消灭后额外为我方全体附上1层【回音】，当【回音】叠加至<color style='color:#f29e38;'> 10 </color>层或以上时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。"
      }
    ],
    "Buffs": [
      {
        "_id": 3031333,
        "Name": "共相",
        "Desc": "「战意汹涌」期间，我方全体速度提高<color style='color:#f29e38;'> 40% </color>，消耗所有【回音】攻击时恢复1个战技点。",
        "SimpleDesc": "我方施放战技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      },
      {
        "_id": 3031343,
        "Name": "悖论",
        "Desc": "我方全体攻击没有对应属性弱点的敌人也能削减韧性，效果等同于原削韧值的<color style='color:#f29e38;'> 50% </color>，无法与其他无视弱点属性削韧效果叠加。「战意汹涌」期间，敌方目标受到的击破伤害提高<color style='color:#f29e38;'> 30% </color>。",
        "SimpleDesc": "我方攻击敌方目标后，每击破1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      },
      {
        "_id": 3031339,
        "Name": "神谱",
        "Desc": "消耗【回音】造成伤害后，我方全体造成的伤害提高<color style='color:#f29e38;'> 60% </color>，持续<color style='color:#f29e38;'> 1 </color>回合。",
        "SimpleDesc": ""
      }
    ],
