    "Blessing": {
      "_id": 3031002,
      "Name": "恶语钝刀",
      "Desc": "敌方目标受到的持续伤害提高<color style='color:#f29e38;'> 35% </color>。受到持续伤害的敌方目标造成的伤害降低<color style='color:#f29e38;'> 35% </color>，被攻击后行动提前<color style='color:#f29e38;'> 35% </color>。"
    },
    "Buffs": [
      {
        "_id": 3031304,
        "Name": "毁谤",
        "Desc": "敌方受到持续伤害时，对相邻目标造成原伤害<color style='color:#f29e38;'> 60% </color>的同属性持续伤害。"
      },
      {
        "_id": 3031305,
        "Name": "谣诼",
        "Desc": "我方攻击敌方目标后，会使目标陷入风化状态，每回合开始时受到固定数值的风属性持续伤害。"
      },
      {
        "_id": 3031306,
        "Name": "诋訾",
        "Desc": "敌方受到持续伤害时，为当前生命值百分比最低的我方目标恢复等同于生命上限<color style='color:#f29e38;'> 10% </color>的生命值，并使其行动提前<color style='color:#f29e38;'> 8% </color>。"
      }
    ],
