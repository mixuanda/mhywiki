  "content": {
    "_id": 2018,
    "Name": "五步抑扬",
    "Blessing": [
      {
        "_id": 3031207,
        "Name": "终结技攻击",
        "Desc": "我方施放终结技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 5 </color>点「战意值」。"
      },
      {
        "_id": 3031208,
        "Name": "战熄潮平",
        "Desc": "敌方目标被任意单位消灭后，为我方全体附上1层【回音】。"
      },
      {
        "_id": 3031209,
        "Name": "战意汹涌",
        "Desc": "进入「战意汹涌」时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。「战意汹涌」期间，敌方目标受到的伤害提高<color style='color:#f29e38;'> 50% </color>，且被任意单位消灭后额外为我方全体附上1层【回音】，当【回音】叠加至<color style='color:#f29e38;'> 10 </color>层或以上时，消耗所有【回音】，每层【回音】对随机敌方目标造成1次固定数值的伤害。"
      }
    ],
    "Buffs": [
      {
        "_id": 3031347,
        "Name": "追想",
        "Desc": "「战意汹涌」期间，我方目标施放终结技后使我方全体造成的伤害提高<color style='color:#f29e38;'> 15% </color>，最多叠加<color style='color:#f29e38;'> 5 </color>层，持续至「战意汹涌」结束。",
        "SimpleDesc": ""
      },
      {
        "_id": 3031348,
        "Name": "犹记",
        "Desc": "进入「战意汹涌」时，立即恢复<color style='color:#f29e38;'> 3 </color>个战技点。「战意汹涌」期间，敌方目标受到的持续伤害提高<color style='color:#f29e38;'> 30% </color>。",
        "SimpleDesc": "敌方目标每次受到持续伤害后，使我方额外积累<color style='color:#f29e38;'> 1 </color>点「战意值」。"
      },
      {
        "_id": 3031349,
        "Name": "颖悟",
        "Desc": "「战意汹涌」期间，我方全体速度提高<color style='color:#f29e38;'> 20% </color>，施放战技后为我方全体附上<color style='color:#f29e38;'> 1 </color>层【回音】。",
        "SimpleDesc": "我方施放战技攻击敌方目标后，每击中1个敌方目标，使我方额外积累<color style='color:#f29e38;'> 3 </color>点「战意值」。"
      }
    ],
