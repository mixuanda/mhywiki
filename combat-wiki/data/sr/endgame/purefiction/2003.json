    },
    "Buffs": [
      {
        "_id": 3031307,
        "Name": "献谄",
        "Desc": "角色的追加攻击造成的伤害提高<color style='color:#f29e38;'> 50% </color>，且触发【怪诞逸闻】的效果后会额外再触发1次效果。"
      },
      {
        "_id": 3031308,
        "Name": "阿谀",
        "Desc": "施放终结技对敌方目标造成伤害时，被视为发动了追加攻击。"
      },
      {
        "_id": 3031309,
        "Name": "便侫",
        "Desc": "角色施放追加攻击击中敌方目标时，我方全体行动提前<color style='color:#f29e38;'> 14% </color>。该效果每次攻击只能触发1次。"
      }
