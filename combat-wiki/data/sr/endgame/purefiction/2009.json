    "Blessing": {
      "_id": 3031005,
      "Name": "怪诞逸闻",
      "Desc": "我方目标击破敌方目标的弱点时会为【怪诞逸闻】充能。当充能达到<color style='color:#f29e38;'> 6 </color>点时，对随机敌方目标造成<color style='color:#f29e38;'> 10 </color>次固定数值的伤害。"
    },
    "Buffs": [
      {
        "_id": 3031324,
        "Name": "咏怀",
        "Desc": "敌方目标受到的击破伤害提高<color style='color:#f29e38;'> 10% </color>，我方攻击后若对敌方造成超击破伤害，则额外为【怪诞逸闻】充能<color style='color:#f29e38;'> 1 </color>点。"
      },
      {
        "_id": 3031325,
        "Name": "画境",
        "Desc": "追加攻击造成的伤害提高<color style='color:#f29e38;'> 50% </color>，追加攻击的弱点击破效率提高<color style='color:#f29e38;'> 50% </color>。"
      },
      {
        "_id": 3031326,
        "Name": "漫笔",
        "Desc": "角色施放终结技进行攻击时，无视敌方目标的弱点造成韧性削减。"
      }
    ],
