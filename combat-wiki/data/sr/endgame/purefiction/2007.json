    "Blessing": {
      "_id": 3031004,
      "Name": "怪诞逸闻",
      "Desc": "我方发动追加攻击攻击敌方目标后，根据本次攻击的目标数量为【怪诞逸闻】充能。当充能达到<color style='color:#f29e38;'> 10 </color>点时，对随机敌方目标造成<color style='color:#f29e38;'> 10 </color>次固定数值的伤害。"
    },
    "Buffs": [
      {
        "_id": 3031319,
        "Name": "篡改",
        "Desc": "触发【怪诞逸闻】效果需要的充能点数减少<color style='color:#f29e38;'> 4 </color>，造成的伤害次数增加<color style='color:#f29e38;'> 4 </color>。"
      },
      {
        "_id": 3031320,
        "Name": "妄言",
        "Desc": "我方角色施放终结技时造成的伤害提高<color style='color:#f29e38;'> 30% </color>，且施放终结技后可令【怪诞逸闻】额外获得<color style='color:#f29e38;'> 2 </color>点充能。"
      },
      {
        "_id": 3031321,
        "Name": "夸大",
        "Desc": "我方角色攻击敌方目标后，可令【怪诞逸闻】额外获得<color style='color:#f29e38;'> 1 </color>点充能。"
      }
