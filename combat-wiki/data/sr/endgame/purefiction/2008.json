    "Blessing": {
      "_id": 3031001,
      "Name": "词语爆裂",
      "Desc": "我方施放终结技攻击敌方目标时，为目标附上【爆裂】，最多叠加<color style='color:#f29e38;'> 6 </color>层。目标的回合开始或目标被消灭时，根据【爆裂】层数对该目标及其相邻目标造成固定数值的伤害。"
    },
    "Buffs": [
      {
        "_id": 3031303,
        "Name": "崩裂",
        "Desc": "持有【爆裂】的敌方目标被消灭时，使我方全体本场战斗中终结技造成的伤害提高<color style='color:#f29e38;'> 15% </color>，最多叠加<color style='color:#f29e38;'> 20 </color>次。"
      },
      {
        "_id": 3031322,
        "Name": "谗慝",
        "Desc": "【爆裂】造成的伤害提高<color style='color:#f29e38;'> 20% </color>，触发时为相邻目标附上1层【爆裂】。"
      },
      {
        "_id": 3031323,
        "Name": "诤语",
        "Desc": "我方施放追加攻击击中敌方目标时，有<color style='color:#f29e38;'> 60% </color>固定概率为目标附上1层【爆裂】。该效果每次攻击对每个敌方目标只能触发1次。"
      }
    ],
