    {
      "blessingId": "31",
      "config": {
        "Name": "舞剑之月",
        "Desc": "当前场上角色的普通攻击、重击或下落攻击在2秒内多次命中敌人后，该角色的普通攻击、重击与下落攻击造成的伤害提升5%，持续8秒，至多叠加15层。该效果每0.1秒至多触发一次，将在角色倒下或退场时清除。"
      }
    },
    {
      "blessingId": "32",
      "config": {
        "Name": "盛放之月",
        "Desc": "当前场上角色视为普通攻击伤害的攻击命中敌人后，有50%的几率在命中敌人的位置释放冲击波，在范围内造成真实伤害。每0.3秒至多通过这种方式释放一次冲击波。",
        "ShockWaveConfig": [
          {
            "ShockWaveDesc": "半径：3m",
            "ShockWaveDMG": 2.4
          }
        ]
      }
    },
    {
      "blessingId": "33",
      "config": {
        "Name": "苏醒之月",
        "Desc": "当前场上角色的普通攻击、重击或下落攻击在2秒内多次命中敌人后，该角色将获得一层「冒头」效果。该效果每0.1秒至多触发一次，持续8秒，「冒头」效果将在角色倒下或退场时清除。角色的「冒头」效果叠加15次之后，会将其清除并释放冲击波，对附近的敌人造成真实伤害。通过这种方式释放冲击波之后的10秒内，队伍中所有角色造成的伤害提升25%。",
        "ShockWaveConfig": [
