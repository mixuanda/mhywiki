  "blessings": [
    {
      "blessingId": "14",
      "config": {
        "Name": "剑舞之月",
        "Desc": "角色的普通攻击在2秒内连续命中敌人时，该角色造成的物理伤害提升5%，持续10秒，至多叠加5层；这些攻击类型同时命中多个敌人时，只能叠加一层。处于5层效果下的角色的攻击命中敌人时，会释放冲击波，造成范围伤害，每1秒至多释放一次冲击波。",
        "ShockWaveConfig": [
          {
            "ShockWaveDesc": "半径：4m",
            "ShockWaveDMG": 1.5
          }
        ]
      }
    },
    {
      "blessingId": "15",
      "config": {
        "Name": "荆棘之月",
        "Desc": "敌人的攻击命中处于护盾庇护下的角色时，会进行反噬：释放冲击波，造成范围伤害。该效果每6秒只能触发一次。",
        "ShockWaveConfig": [
          {
            "ShockWaveDesc": "半径：4m",
            "ShockWaveDMG": 15
          }
        ]
      }
    },
    {
      "blessingId": "16",
      "config": {
        "Name": "叛逆之月",
        "Desc": "角色的物理属性的普通攻击、重击或下落攻击命中敌人时，该角色的暴击率提升3%，持续10秒，至多叠加5层；这些攻击类型同时命中多个敌人时，只能叠加一层。处于5层效果下的角色的攻击造成暴击时，会释放冲击波，造成范围伤害，每1秒至多释放一次冲击波。",
        "ShockWaveConfig": [
          {
            "ShockWaveDesc": "半径：4m",
            "ShockWaveDMG": 2
          }
        ]
      }
    }
