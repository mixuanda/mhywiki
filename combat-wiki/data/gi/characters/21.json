      "_AvatarCostumeConfig_": {
        "21": {
          "Costumes": [
            {
              "ID": 340007,
              "Name": "100%侦察骑士",
              "Desc": "安柏的装扮款式。这一次出现的，是更为正式也更为英气的侦察骑士哦！",
              "Icon": "UI_AvatarIcon_AmborCostumeWic",
              "Quality": 4
            },
            {
              "ID": 0,
              "Name": "「满分的侦察骑士」",
              "Desc": "安柏的装扮款式。具备高机动性的侦察骑士服装。",
              "Icon": "",
              "Quality": 0
            }
          ],
          "Dish": {
            "ID": 108010,
            "JD": 108009,
            "Name": "<b>侦察骑士烤肉！</b>",
            "Eff": "复苏选中的角色，为其恢复生命值上限的10%，并额外恢复150点生命值。",
            "Desc": "安柏的特色料理。一面泛着血色，另一面散发着微妙焦香气味的肉排。闭着眼大口吃下去，安柏会很高兴的吧。",
            "Recipe": {
              "100061": 2
            },
            "Icon": "UI_ItemIcon_108010"
          },
          "Namecard": {
            "Name": "<b>安柏 · 兔兔</b>",
            "Desc": "名片纹饰。<br>「是兔兔伯爵哦！」",
            "Pic": "UI_NameCardPic_Ambor_P"
          }
        }
      },
      "acs_cache_": {
        "340007": "最近三个月，安柏对钩钩果颇有意见。野外侦查期间她的制服和长袜意外被尖锐的果子勾破了，而她最近太过忙碌，抽不出时间做缝补工作。<br>当初骑士团后勤小队给她发了三套同款制服用以替换，损坏一件问题也不大。但安柏非常珍惜这三套制服，无论哪件损坏了，她都会感到痛心。<br>就连我的兔兔伯爵，也是照着这些制服配色设计的呢！安柏悲伤地想。<br><br>任务结束后，安柏找来针线把破损处补好，可惜无论手怎么巧，布料上都留有缝补的痕迹。<br>不过仅仅过了半个月，安柏就在骑士团年终会议上领到了新制服。<br>比原来更正式，设计上似乎也更为精美。而且，似乎不容易勾坏！<br>后勤小队的赫塔队长是这样说的：「代表西风骑士团，向唯一的侦察骑士送上新衣服！非常感谢你一直以来的努力。」"
      }
    }
