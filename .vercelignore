# Ignore everything by default, then whitelist only runtime-required files.
*

# Core deploy config and Python deps.
!.vercelignore
!vercel.json
!requirements.txt

# Vercel server entrypoint.
!api/
!api/index.py

# Runtime modules imported by api/index.py -> tools/admin_server.py.
!tools/
!tools/admin_server.py
!tools/ingest_human_text.py
!tools/legacy_sync.py
!tools/normalize.py

# Canonical data used by admin APIs.
!combat-wiki/
!combat-wiki/data/
!combat-wiki/data/**

# Web runtime assets (combat-only site + admin).
!web/
!web/index.html
!web/index/
!web/index/**
!web/home/
!web/home/**
!web/admin/
!web/admin/**
!web/plugins/
!web/plugins/**
!web/javascripts/
!web/javascripts/**
!web/stylesheets/
!web/stylesheets/**
!web/data/
!web/data/**
!web/fonts/
!web/fonts/**
!web/Char/
!web/Char/**
!web/gi/
!web/gi/**
!web/sr/
!web/sr/**
!web/yhb/
!web/yhb/**
!web/favicon.ico
